<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Simulation Report - <%= project.projectName %></title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Plus Jakarta Sans', sans-serif;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    
    body {
      background: #eef2f6;
    }

    @page {
      size: A4;
      margin: 0;
    }

    /* Fixed Page for Cover to ensure proper positioning without overflow */
    .page-fixed {
      width: 210mm;
      height: 297mm;
      background: #ffffff;
      position: relative;
      page-break-after: always;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Flow Page for lists to span multiple pages naturally */
    .page-flow {
      width: 210mm;
      min-height: 297mm;
      background: #ffffff;
      position: relative;
      page-break-after: always;
      display: block; /* use block instead of flex to allow content to break properly */
    }
    
    .page-fixed:last-child, .page-flow:last-child {
      page-break-after: auto;
    }

    /* Colors & Gradients */
    :root {
      --dark-green: #0a261c;
      --card-green: #113628;
      --gold-light: #f7d273;
      --gold-mid: #d4af37;
      --gold-dark: #b89523;
      --gold-gradient: linear-gradient(90deg, #d4af37 0%, #f7d273 50%, #d4af37 100%);
      --bg-cream: #faf9f6;
      --text-gray: #4a5568;
    }

    /* Top Banner / Header */
    .header-banner {
      background-color: var(--dark-green);
      color: white;
      padding: 15mm 15mm 10mm 15mm;
      position: relative;
      border-bottom: 5px solid var(--gold-mid);
    }
    .header-banner::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background-image: url("data:image/svg+xml,%3Csvg width='100%25' height='100%25' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0,50 C150,150 250,0 400,100 C550,200 650,50 800,150 L800,0 L0,0 Z' fill='%23d4af37' fill-opacity='0.05'/%3E%3Cpath d='M0,150 C200,50 300,200 500,100 C700,0 750,150 800,100 L800,0 L0,0 Z' fill='%23f7d273' fill-opacity='0.03'/%3E%3C/svg%3E");
      background-size: cover;
      opacity: 0.8;
      z-index: 0;
    }
    .header-content {
      position: relative;
      z-index: 1;
    }

    .brand-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 20pt;
      font-weight: 800;
      color: var(--gold-mid);
      margin-bottom: 15px;
    }
    .brand-logo svg {
      width: 28px;
      height: 28px;
      fill: var(--gold-mid);
    }
    
    .header-title {
      font-size: 24pt;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      line-height: 1.2;
      margin-bottom: 5px;
    }
    .header-subtitle {
      font-size: 14pt;
      font-weight: 500;
      color: #e2e8f0;
    }

    .page-content {
      flex: 1;
      padding: 10mm 15mm;
      background-color: var(--bg-cream);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    /* Content for Flow pages shouldn't stretch flex-direction, just normal margin */
    .page-flow .page-content {
      display: block;
    }

    /* Grid Layouts */
    .grid-2-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      align-items: start;
    }

    /* Cards */
    .card {
      background: white;
      border-radius: 12px;
      padding: 12px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.03);
      border: 1px solid #f1f1f1;
      break-inside: avoid;
    }
    .card-header {
      font-size: 12pt;
      font-weight: 700;
      color: var(--dark-green);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-header svg {
      width: 16px;
      height: 16px;
      fill: var(--gold-mid);
    }
    .card-dark {
      background: var(--card-green);
      color: white;
    }
    .card-dark .card-header {
      color: var(--gold-mid);
    }

    /* Info Lists */
    .info-list {
      list-style: none;
    }
    .info-list li {
      display: flex;
      margin-bottom: 10px;
      font-size: 9.5pt;
    }
    .info-list li .label {
      width: 90px;
      color: var(--text-gray);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .info-list li .label svg {
      width: 12px;
      height: 12px;
      fill: var(--gold-dark);
    }
    .info-list li .value {
      font-weight: 600;
      color: #1a202c;
      flex: 1;
    }
    .card-dark .info-list li .label { color: #cbd5e1; }
    .card-dark .info-list li .value { color: white; }

    /* Bar Charts */
    .bar-row {
      display: flex;
      align-items: center;
      margin-bottom: 8px;
    }
    .bar-label {
      width: 30px;
      font-weight: 700;
      font-size: 9pt;
      color: var(--dark-green);
    }
    .bar-track {
      flex: 1;
      height: 8px;
      background: #e2e8f0;
      border-radius: 4px;
      margin: 0 8px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      background: var(--card-green);
      border-radius: 4px;
    }
    .bar-value {
      width: 25px;
      text-align: right;
      font-weight: 700;
      font-size: 9pt;
    }

    /* McFarlan Matrix */
    .mcfarlan-container {
      position: relative;
      width: 100%;
      aspect-ratio: 1;
      border: 2px solid var(--gold-mid);
      border-radius: 8px;
      background: var(--card-green);
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      margin-bottom: 15px;
    }
    .mcfarlan-quad {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9pt;
      font-weight: 600;
      color: rgba(255,255,255,0.6);
      text-align: center;
    }
    .mcfarlan-axis-x { position: absolute; bottom: -20px; width: 100%; text-align: center; font-size: 8pt; color: #cbd5e1; }
    .mcfarlan-axis-y { position: absolute; left: -25px; top: 50%; transform: translateY(-50%) rotate(-90deg); font-size: 8pt; color: #cbd5e1; }
    
    <% 
      const mx = project.mcfarlan.coordinates.x; 
      const my = project.mcfarlan.coordinates.y;
      const dotX = Math.min(Math.max((mx / 5) * 100, 5), 95);
      const dotY = Math.min(Math.max(100 - (my / 5) * 100, 5), 95);
    %>
    .mcfarlan-dot {
      position: absolute;
      width: 10px;
      height: 10px;
      background: var(--gold-mid);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      left: <%= dotX %>%;
      top: <%= dotY %>%;
      box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.4);
    }

    .mcfarlan-status {
      text-align: center;
      margin-top: 5px;
      padding: 8px;
      border: 1px solid rgba(212, 175, 55, 0.3);
      border-radius: 8px;
    }
    .mcfarlan-status h4 { color: var(--gold-mid); font-size: 11pt; margin-bottom: 2px; text-transform: uppercase; }

    /* Tables */
    .styled-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10px;
      background: white;
      border-radius: 8px;
      overflow: hidden;
      font-size: 9.5pt;
      break-inside: avoid;
    }
    .styled-table thead {
      background: #f1f5f9;
    }
    .styled-table th {
      padding: 10px;
      text-align: left;
      font-weight: 700;
      color: var(--text-gray);
    }
    .styled-table tbody tr {
      border-bottom: 1px solid #e2e8f0;
      page-break-inside: avoid;
    }
    .styled-table tbody tr:nth-of-type(even) { background: #f8fafc; }
    .styled-table td {
      padding: 10px;
      color: #1a202c;
    }
    .text-right { text-align: right !important; }
    .text-center { text-align: center !important; }
    
    .table-total {
      background: var(--gold-gradient);
      color: var(--dark-green);
      font-weight: 800;
      border-radius: 8px;
      padding: 10px 15px;
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
      font-size: 11pt;
      break-inside: avoid;
    }

    /* Financial Result Blocks */
    .fin-result-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
      background: #f8fafc;
      padding: 8px;
      border-radius: 8px;
      border: 1px solid #e2e8f0;
      break-inside: avoid;
    }
    .fin-label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      font-size: 10pt;
      width: 50%;
    }
    .fin-label svg { width: 18px; height: 18px; fill: var(--gold-mid); }
    .fin-value {
      background: var(--card-green);
      color: white;
      padding: 5px 10px;
      border-radius: 6px;
      font-weight: 800;
      font-size: 11pt;
      text-align: center;
      min-width: 90px;
    }
    .fin-value.gold {
      background: var(--gold-mid);
      color: var(--dark-green);
    }

    /* Wide Bottom Banners */
    .bottom-insight {
      background: var(--card-green);
      color: white;
      padding: 15px;
      border-radius: 12px;
      margin-top: auto;
      border-left: 5px solid var(--gold-mid);
      position: relative;
      break-inside: avoid;
    }
    .bottom-insight h3 {
      color: var(--gold-mid);
      font-size: 12pt;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .bottom-insight h3 svg { width: 18px; height: 18px; fill: var(--gold-mid); }
    .bottom-insight p { font-size: 9pt; line-height: 1.5; color: #e2e8f0; }

    /* SVG Icons (Inline for PDF) */
    .icon { display: inline-block; }
  </style>
</head>
<body>

  <!-- =============================== PAGE 1: EXECUTIVE SUMMARY =============================== -->
  <div class="page-fixed">
    <div class="header-banner">
      <div class="header-content">
        <div class="brand-logo">
          <svg viewBox="0 0 24 24"><path d="M3 3h18v2H3V3m0 16h18v2H3v-2m0-8h18v2H3v-2m4-4h14v2H7V7m-4 0h2v2H3V7c0 0 0 0 0 0m4 8h14v2H7v-2m-4 0h2v2H3v-2z"/></svg>
          InvesTechy
        </div>
        <div class="header-title"><%= project.projectName %></div>
        <div class="header-subtitle">Executive Summary</div>
      </div>
    </div>

    <div class="page-content">
      <div class="grid-2-col" style="grid-template-columns: 1fr 0.8fr;">
        <!-- Left Col -->
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <!-- Project Info -->
          <div class="card">
            <div class="card-header">
              <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg>
              Project Overview
            </div>
            <ul class="info-list">
              <li>
                <span class="label"><svg viewBox="0 0 24 24"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg> Name:</span>
                <span class="value"><%= project.projectName %></span>
              </li>
              <li>
                <span class="label"><svg viewBox="0 0 24 24"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/></svg> Industry:</span>
                <span class="value"><%= project.industry %></span>
              </li>
              <li>
                <span class="label"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg> Scale:</span>
                <span class="value"><%= project.scale %></span>
              </li>
              <li>
                <span class="label"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 9h-2V7h-2v5H6v2h2v5h2v-5h2v-2z"/></svg> Plan:</span>
                <span class="value"><%= project.plan %></span>
              </li>
              <li>
                <span class="label"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg> Location:</span>
                <span class="value"><%= project.location %></span>
              </li>
            </ul>
          </div>

          <!-- Business Domain -->
          <div class="card">
            <div class="card-header">
              <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/><path d="M7 12h2v5H7zm4-3h2v8h-2zm4-3h2v11h-2z"/></svg>
              Business Domain Scores
            </div>
            <% Object.entries(project.businessDomain).forEach(([key, value]) => { %>
              <div class="bar-row">
                <div class="bar-label"><%= key %></div>
                <div class="bar-track"><div class="bar-fill" style="width: <%= (value/5)*100 %>%;"></div></div>
                <div class="bar-value"><%= Number(value).toFixed(1) %></div>
              </div>
            <% }) %>
          </div>

          <!-- Tech Domain -->
          <div class="card" style="margin-top: -5px;">
            <div class="card-header">
              <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/><path d="M7 12h10v2H7z"/></svg>
              Technology Domain Scores
            </div>
            <% Object.entries(project.technologyDomain).forEach(([key, value]) => { %>
              <div class="bar-row">
                <div class="bar-label"><%= key %></div>
                <div class="bar-track"><div class="bar-fill" style="width: <%= (value/5)*100 %>%;"></div></div>
                <div class="bar-value"><%= Number(value).toFixed(1) %></div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Right Col -->
        <div class="card card-dark" style="height: 100%; display: flex; flex-direction: column;">
          <div class="card-header">McFarlan Matrix</div>
          <div style="flex: 1; display: flex; flex-direction: column;">
            <div class="mcfarlan-container">
              <!-- Investment: Top Left -->
              <div class="mcfarlan-quad" style="border-bottom: 2px solid #d4af37; border-right: 2px solid #d4af37;">Investment</div>
              <!-- Strategic: Top Right -->
              <div class="mcfarlan-quad" style="border-bottom: 2px solid #d4af37;">Strategic</div>
              <!-- Infrastructure: Bottom Left -->
              <div class="mcfarlan-quad" style="border-right: 2px solid #d4af37;">Infrastructure</div>
              <!-- Breakthrough Management: Bottom Right -->
              <div class="mcfarlan-quad">Breakthrough Manage...</div>
              
              <div class="mcfarlan-dot"></div>
              <div class="mcfarlan-axis-x">Current Impact &rarr;</div>
              <div class="mcfarlan-axis-y">Future Impact &rarr;</div>
            </div>
            <div class="mcfarlan-status">
              <h4>Current: <%= project.mcfarlan.quadrant %></h4>
              <p style="font-size: 8.5pt; color: #cbd5e1;">Coordinates: (X: <%= mx.toFixed(2) %>, Y: <%= my.toFixed(2) %>)</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bottom-insight">
        <h3>
          <svg viewBox="0 0 24 24"><path d="M12 22q-1.25 0-2.125-.875T9 19h6q0 1.25-.875 2.125T12 22zm-3-4q0-.425.288-.712T10 17h4q.425 0 .713.288T15 18q0 .425-.288.713T14 19h-4q-.425 0-.712-.288T9 18zm-.5-3q-1.725-1.025-2.738-2.75T4.75 8.5q0-3.125 2.188-5.312T12 1q3.125 0 5.313 2.188T19.5 8.5q0 2-.962 3.75T15.5 15H8.5z"/></svg>
          Key Insight
        </h3>
        <p>The project is positioned in the <strong><%= project.mcfarlan.quadrant %></strong> quadrant, indicating its significance in both current operational impact and future strategic potential. Based on the calculated scores from business and technology dimensions, a high-priority investment review is recommended to maximize value realization.</p>
      </div>
    </div>
  </div>

  <!-- =============================== PAGE 2: FINANCIAL BREAKDOWN (FLOWING LISTS) =============================== -->
  <div class="page-flow">
    <div class="header-banner" style="padding: 15mm 15mm 10mm 15mm;">
      <div class="header-content">
        <div class="brand-logo" style="font-size: 16pt; margin-bottom: 5px;">
          <svg viewBox="0 0 24 24"><path d="M3 3h18v2H3V3m0 16h18v2H3v-2m0-8h18v2H3v-2m4-4h14v2H7V7m-4 0h2v2H3V7m4 8h14v2H7v-2z"/></svg>
          InvesTechy
        </div>
        <div class="header-title" style="font-size: 20pt;">FINANCIAL BREAKDOWN</div>
        <div class="header-subtitle" style="font-size: 12pt;">Investment & Benefit Analysis</div>
      </div>
    </div>

    <!-- Allow page content to break cleanly -->
    <div class="page-content" style="gap: 20px;">
      
      <!-- CAPEX -->
      <div style="break-inside: auto;">
        <h2 style="font-size: 14pt; margin-bottom: 10px; color: var(--dark-green);">CAPEX (Capital Expenditure)</h2>
        <table class="styled-table">
          <thead>
            <tr>
              <th style="width:50%;">Item</th>
              <th class="text-right">Nominal</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <% let totalCapex = 0; simulatedData.capex.forEach(item => { totalCapex += Number(item.nominal) || 0; %>
            <tr>
              <td><strong><%= item.item %></strong></td>
              <td class="text-right fw-bold">Rp <%= (Number(item.nominal) || 0).toLocaleString('id-ID') %></td>
              <td style="color: var(--text-gray); font-size: 8.5pt;"><%= item.description || '-' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="table-total">
          <span>Total CAPEX</span>
          <span>Rp <%= totalCapex.toLocaleString('id-ID') %></span>
        </div>
      </div>

      <!-- OPEX -->
      <div style="break-inside: auto;">
        <h2 style="font-size: 14pt; margin-bottom: 10px; color: var(--dark-green);">OPEX (Operational Expenditure - Base Year)</h2>
        <table class="styled-table">
          <thead>
             <tr>
              <th style="width:50%;">Item</th>
              <th class="text-right">Nominal</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <% let totalOpex = 0; simulatedData.opex.forEach(item => { totalOpex += Number(item.nominal) || 0; %>
            <tr>
              <td><strong><%= item.item %></strong></td>
              <td class="text-right fw-bold">Rp <%= (Number(item.nominal) || 0).toLocaleString('id-ID') %></td>
              <td style="color: var(--text-gray); font-size: 8.5pt;"><%= item.description || '-' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="table-total">
          <span>Total OPEX (Year 1)</span>
          <span>Rp <%= totalOpex.toLocaleString('id-ID') %></span>
        </div>
      </div>

      <!-- BENEFITS -->
      <div style="break-inside: auto;">
        <h2 style="font-size: 14pt; margin-bottom: 10px; color: var(--dark-green);">Benefits Overview</h2>
        
        <!-- Since Benefits can be long, we wrap cards individually so they can break if needed -->
        <% let totalBenefit = 0; %>
        
        <div class="card" style="border-top: 4px solid var(--dark-green); margin-bottom: 15px;">
          <div class="card-header" style="justify-content: center; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px;">
            Tangible Benefits
          </div>
          <div class="grid-2-col">
            <% simulatedData.tangibleBenefits.forEach(item => { totalBenefit += Number(item.nominal) || 0; %>
              <div style="text-align: center; margin-bottom: 10px; break-inside: avoid;">
                <h4 style="color: #1a202c; font-size: 10pt;"><%= item.item %></h4>
                <div style="font-size: 12pt; font-weight: 800; color: var(--card-green); margin: 5px 0;">Rp <%= (Number(item.nominal) || 0).toLocaleString('id-ID') %></div>
                <div style="font-size: 8.5pt; color: var(--text-gray);"><%= item.description || 'Estimated value' %></div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="card" style="border-top: 4px solid var(--gold-mid); margin-bottom: 15px;">
          <div class="card-header" style="justify-content: center; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px;">
            Intangible Benefits
          </div>
          <div class="grid-2-col">
            <% simulatedData.intangibleBenefits.forEach(item => { totalBenefit += Number(item.nominal) || 0; %>
              <div style="text-align: center; margin-bottom: 10px; break-inside: avoid;">
                <h4 style="color: #1a202c; font-size: 10pt;"><%= item.item %></h4>
                <div style="font-size: 12pt; font-weight: 800; color: var(--card-green); margin: 5px 0;">Rp <%= (Number(item.nominal) || 0).toLocaleString('id-ID') %></div>
                <div style="font-size: 8.5pt; color: var(--text-gray);"><%= item.description || 'Estimated value' %></div>
              </div>
            <% }) %>
          </div>
        </div>
        
        <div class="table-total" style="background: var(--dark-green); color: var(--gold-mid); justify-content: center; font-size: 14pt;">
          <div style="text-align: center;">
            <div style="font-size: 9pt; font-weight: 500; margin-bottom: 5px;">Total Estimated Benefits (Year 1)</div>
            Rp <%= totalBenefit.toLocaleString('id-ID') %>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- =============================== PAGE 3: SIMULATION & FEASIBILITY =============================== -->
  <!-- Note: We use page-flow here as well so it starts on a fresh page naturally if content before it ended -->
  <div class="page-flow" style="page-break-before: always;">
    <div class="header-banner" style="padding: 15mm 15mm 10mm 15mm;">
      <div class="header-content">
        <div class="brand-logo" style="font-size: 16pt; margin-bottom: 5px;">
          <svg viewBox="0 0 24 24"><path d="M3 3h18v2H3V3m0 16h18v2H3v-2m0-8h18v2H3v-2m4-4h14v2H7V7m-4 0h2v2H3V7m4 8h14v2H7v-2z"/></svg>
          InvesTechy
        </div>
        <div class="header-title" style="font-size: 20pt;">SIMULATION & FEASIBILITY</div>
        <div class="header-subtitle" style="font-size: 12pt;">Scenario: <%= scenarioName %></div>
      </div>
    </div>

    <div class="page-content">
      <div class="grid-2-col" style="grid-template-columns: 0.8fr 1.2fr;">
        
        <!-- Left: Fin Results -->
        <div>
          <h2 style="font-size: 13pt; margin-bottom: 12px; color: var(--dark-green);">Financial Results</h2>
          
          <div class="fin-result-row">
            <div class="fin-label">
              <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
              NPV
            </div>
            <div class="fin-value">Rp <%= (financialResults.npv / 1000000).toFixed(1) %>M</div>
          </div>
          
          <div class="fin-result-row">
            <div class="fin-label">
              <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3z"/></svg>
              ROI
            </div>
            <div class="fin-value"><%= financialResults.roi.toFixed(1) %>%</div>
          </div>

          <div class="fin-result-row">
            <div class="fin-label">
              <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/><path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
              Payback
            </div>
            <div class="fin-value"><%= financialResults.paybackPeriod.toFixed(2) %> Yrs</div>
          </div>

          <div class="fin-result-row">
            <div class="fin-label">
              <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/></svg>
              Break Even
            </div>
            <div class="fin-value">Year <%= financialResults.breakEvenYear %></div>
          </div>

          <div class="fin-result-row">
            <div class="fin-label">
              <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
              IE Score
            </div>
            <div class="fin-value" style="background: var(--dark-green); color: var(--gold-light);"><%= financialResults.ieScore %> / 100</div>
          </div>

          <div class="fin-result-row" style="background: var(--gold-light); border: none;">
            <div class="fin-label" style="color: var(--dark-green); width: auto;">Feasibility:</div>
            <div style="font-weight: 800; color: var(--dark-green); font-size: 10pt;"><%= financialResults.feasibilityStatus %></div>
          </div>
        </div>

        <!-- Right: Chart -->
        <div class="card" style="padding: 15px; display: flex; flex-direction: column;">
          <h2 style="font-size: 11pt; margin-bottom: 20px; color: var(--dark-green); text-align: center;">Cash Flow & Break-Even Analysis</h2>
          <div style="flex: 1; position: relative;">
            <canvas id="breakEvenChart"></canvas>
          </div>
        </div>
      </div>

      <h2 style="font-size: 13pt; margin-top: 5px; margin-bottom: 10px; color: var(--dark-green);">Break-Even Table</h2>
      <table class="styled-table">
        <thead>
          <tr>
            <th>Year</th>
            <th class="text-right">Net Cash Flow</th>
            <th class="text-right">Cumulative Cash Flow</th>
          </tr>
        </thead>
        <tbody>
          <% if (financialResults.breakEvenAnalysisDetail && financialResults.breakEvenAnalysisDetail.length > 0) { %>
            <% financialResults.breakEvenAnalysisDetail.forEach(bp => { %>
            <tr>
              <td>Year <%= bp.year %></td>
              <td class="text-right" style="<%= bp.net < 0 ? 'color: #dc2626;' : '' %>">
                <%= bp.net < 0 ? '-' : '' %>Rp <%= Math.abs(bp.net).toLocaleString('id-ID') %>
              </td>
              <td class="text-right fw-bold" style="<%= bp.cumulativeNet < 0 ? 'color: #dc2626;' : 'color: #16a34a;' %>">
                <%= bp.cumulativeNet < 0 ? '-' : '' %>Rp <%= Math.abs(bp.cumulativeNet).toLocaleString('id-ID') %>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>

      <!-- Using break-inside: avoid on insight so it doesn't split midway naturally -->
      <div class="bottom-insight" style="margin-top: 15px;">
        <h3>
          <svg viewBox="0 0 24 24"><path d="M12 22q-1.25 0-2.125-.875T9 19h6q0 1.25-.875 2.125T12 22zm-3-4q0-.425.288-.712T10 17h4q.425 0 .713.288T15 18q0 .425-.288.713T14 19h-4q-.425 0-.712-.288T9 18zm-.5-3q-1.725-1.025-2.738-2.75T4.75 8.5q0-3.125 2.188-5.312T12 1q3.125 0 5.313 2.188T19.5 8.5q0 2-.962 3.75T15.5 15H8.5z"/></svg>
          Conclusion
        </h3>
        <p>Strong financial performance with <strong><%= financialResults.roi.toFixed(1) %>% ROI</strong> and <strong><%= financialResults.paybackPeriod.toFixed(1) %>-year</strong> payback period. Break-even point is reached in <strong>Year <%= financialResults.breakEvenYear %></strong>. The project is <strong><%= financialResults.feasibilityStatus.toLowerCase() %></strong> based on Information Economics assessment.</p>
      </div>
    </div>
  </div>

  <script>
    // Prepare Data for Chart
    const rawData = <%- JSON.stringify(financialResults.breakEvenAnalysisDetail || []) %>;
    
    if (rawData && rawData.length > 0) {
        const labels = rawData.map(d => 'Year ' + d.year);
        const netData = rawData.map(d => d.net);
        const cumulativeData = rawData.map(d => d.cumulativeNet);

        const ctx = document.getElementById('breakEvenChart').getContext('2d');
        
        // Disable animations so Puppeteer captures it immediately
        Chart.defaults.animation = false;

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        type: 'line',
                        label: 'Cumulative Cash Flow',
                        data: cumulativeData,
                        borderColor: '#d4af37',
                        backgroundColor: '#d4af37',
                        borderWidth: 3,
                        pointBackgroundColor: '#d4af37',
                        pointRadius: 4,
                        fill: false,
                        yAxisID: 'y'
                    },
                    {
                        type: 'bar',
                        label: 'Net Cash Flow',
                        data: netData,
                        backgroundColor: '#113628',
                        borderRadius: 4,
                        yAxisID: 'y'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { boxWidth: 12, font: { family: "'Plus Jakarta Sans', sans-serif" } }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false }
                    },
                    y: {
                        grid: { borderDash: [4, 4] },
                        ticks: {
                            callback: function(value) {
                                return value / 1000000 + 'M'; // Format as millions for brevity
                            }
                        }
                    }
                }
            }
        });
    }
  </script>
</body>
</html>
